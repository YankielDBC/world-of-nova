TELEGRAM_BOT_TOKEN=__REPLACE_WITH_YOUR_TOKEN__
# Local dev default (SQLite)
DATABASE_URL="file:./dev.db"
# For PostgreSQL deployment, replace DATABASE_URL with:
# DATABASE_URL="postgresql://__USER__:__PASS__@__HOST__:5432/__DB__?schema=public"
# Optional Redis URL for distributed conversation state
REDIS_URL=""
# Bot transport mode: polling | webhook
BOT_TRANSPORT_MODE="polling"
# Required when BOT_TRANSPORT_MODE=webhook
WEBHOOK_URL=""
WEBHOOK_PORT=3000
ENABLE_BACKGROUND_WORKERS=true
DAY_CYCLE_ENABLED=true
DAY_CYCLE_ANCHOR_ISO="2026-01-01T00:00:00Z"
DAY_CYCLE_DAWN_MINUTES=20
DAY_CYCLE_DAY_MINUTES=280
DAY_CYCLE_DUSK_MINUTES=20
DAY_CYCLE_NIGHT_MINUTES=160
MERCHANT_FORCE_COORDS=""
MERCHANT_COUNT=2
MERCHANT_SWEEP_INTERVAL_MS=15000
MERCHANT_STAY_MIN_SECONDS=300
MERCHANT_STAY_MAX_SECONDS=3600
MERCHANT_RUMOR_RADIUS=18
MERCHANT_ETA_SECONDS_PER_TILE=3
MERCHANT_ALERTS_CHANNEL="@rpgalert"
MERCHANT_PERIMETER_MARGIN=10
MERCHANT_MAX_DISTANCE_TO_DISCOVERED=12
MERCHANT_FALLBACK_RADIUS=25

DEBUG_LOGS=false
PERF_METRICS_ENABLED=true
PERF_REPORT_INTERVAL_MS=60000
PERF_SAMPLE_LIMIT=300
INSPECT_NODE_CACHE_TTL_MS=30000
GATHERABLE_CACHE_TTL_MS=30000
RECOVERY_SWEEP_INTERVAL_MS=10000
PLAYER_QUEUE_MAX_CONCURRENCY=24
PLAYER_QUEUE_MAX_PENDING=2000
PLAYER_QUEUE_MAX_PENDING_PER_PLAYER=6
# Durable job sweeper (movement/venture async jobs)
JOB_SWEEP_INTERVAL_MS=1000
JOB_SWEEP_BATCH_SIZE=50
# If a RUNNING job stays locked beyond this time, recover it automatically
JOB_RUNNING_LOCK_TIMEOUT_MS=90000
